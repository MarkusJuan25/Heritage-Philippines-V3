# Heritage Philippines V3 — Web Application Environment Variables
#
# This file is a template only: copy it to .env.local (gitignored) and
# fill in real local values. Never commit real secrets, connection strings,
# tokens, or domains — only this .env.example template is tracked in git
# (see .gitignore). Each variable below is added only once the feature that
# needs it is actually implemented (never in advance).
#
# Full naming, isolation, and secret-handling strategy — including the
# server-only vs. NEXT_PUBLIC_ rule, secret generation/rotation/exposure
# response, and the database/auth/email/storage boundaries — is defined
# in docs/HERITAGE_V3_ENVIRONMENT_CONFIGURATION.md. See that document
# before adding a new variable here.

# --- Database (server-only) ---------------------------------------------
# PostgreSQL connection string. Prisma's own conventional variable name
# (apps/web/prisma/schema.prisma; environment-configuration guide Section
# 5's naming-exception rule) — required in every environment. Never a
# shared database across local/staging/production (environment-
# configuration guide Section 3).
DATABASE_URL="postgresql://user:password@localhost:5432/heritage_v3_dev?schema=public"

# --- Authentication / sessions (server-only) -----------------------------
# Better Auth's own conventional variable names (docs/HERITAGE_V3_DECISIONS_LOG.md
# D-011). Required in every environment; unique per environment; never
# reused between staging and production (environment-configuration guide
# Section 7). Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="generate-a-unique-32+-character-secret-per-environment"

# The base URL this app is served from in the current environment (used to
# validate auth callback/redirect targets). Local default shown; set to the
# real staging/production origin in those environments.
BETTER_AUTH_URL="http://localhost:3000"

# --- Dev seed script (optional; local only) -------------------------------
# `pnpm db:seed` (apps/web/prisma/seed.ts) creates one known-fixed-password
# account per role. It refuses to run in NODE_ENV=production, and — since
# `pnpm db:seed` runs outside Next.js and NODE_ENV alone can't be trusted —
# it also refuses to target any DATABASE_URL whose host isn't localhost/
# 127.0.0.1/::1, unless SEED_ALLOW_REMOTE_DATABASE is explicitly set below.
# Leave both unset for normal local development.

# Overrides the fixed seed-account password (default: ChangeMe123!Dev).
# Never a real credential; never committed.
# SEED_USER_PASSWORD="ChangeMe123!Dev"

# Set to "true" only to deliberately seed a non-local, disposable
# development/staging database. Never set this for a database that holds
# any real data.
# SEED_ALLOW_REMOTE_DATABASE="true"
